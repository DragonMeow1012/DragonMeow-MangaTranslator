# 程式本體在 app/；模型、venv、執行產物等都在 app/ 底下，這裡一併忽略

# 模型權重 / 大檔（zip release 才附）
/app/models
*.ckpt
*.pt
*.onnx

# 虛擬環境
.venv/
/venv
pyvenv.cfg
/Scripts/
/Lib/
/include/
/share/

# 環境變數（含 API key）
.env
*.local
*.local.*

# 執行產物
result
/app/logs/
/app/fonts/user/
/app/input/
/app/input-translated/
ocrs
Manga
Manga-translated

# 快取 / 雜項
__pycache__
.vscode
.idea
.history
.DS_Store
dev/

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# SSL（本機 server）
cert.pem
key.pem

# 備份 / 暫存
*.bak
*.bak.*
/_crops/
/_test*
/_testcfg.json

# 可攜式 Python（隨 release 另附 zip 讓用戶丟進根目錄，勿入庫）
/python/
/python-portable*.zip

# Release 打包產物（手動打包，勿入庫）
/DragonMeow-MangaTranslator-*.zip
/_tmp_pack*.py
