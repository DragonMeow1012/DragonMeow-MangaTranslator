# 複製這個檔案為 .env 並填入你的 Gemini API key
# 取得 API key：https://aistudio.google.com/apikey

# 必填：Gemini API key（可設多把 GEMINI_API_KEY1、GEMINI_API_KEY2... 撞到 429 額度時自動輪替）
GEMINI_API_KEY=your_api_key_here
# GEMINI_API_KEY1=
# GEMINI_API_KEY2=

# 翻譯 / OCR 用的 Gemini 模型（預設 gemini-3.1-flash-lite）
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_VISION_MODEL=gemini-3.1-flash-lite

# worker 數量（每個 worker 各載一份模型、各佔一份 VRAM）
# MT_NUM_WORKERS=1
# 每個 worker 的並發數（GPU 階段會排隊，但 LLM 翻譯階段可重疊）
# MT_WORKER_CONCURRENCY=5

# 渲染字型（絕對路徑；未設則用 fonts/ 內建台北黑體）
# MANGA_TRANSLATOR_FONT_PATH=

# 翻譯溫度（預設 0.3）
# GEMINI_2STAGE_TEMP=0.3
